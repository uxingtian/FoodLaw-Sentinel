# Production profile for resume-level verification.
#
# Copy this file to .env and replace placeholder hosts/keys with real services.

DATA_DIR=data
REPORTS_DIR=reports
DEFAULT_TOP_K=5

# Qwen/DeepSeek/vLLM OpenAI-compatible chat service.
OPENAI_API_KEY=replace-with-production-key
OPENAI_BASE_URL=http://<vllm-host>:8000/v1
QA_MODEL=Qwen3-72B-Chat

# Real embedding service.
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_API_KEY=replace-with-embedding-key
EMBEDDING_BASE_URL=http://<embedding-host>:8000/v1
EMBEDDING_MODEL=qwen3-embedding-0.6b

# Chroma vector backend.
VECTOR_BACKEND=chroma

# HTTP reranker service.
RERANKER_PROVIDER=http
RERANKER_API_KEY=
RERANKER_URL=http://<reranker-host>:8000/rerank
RERANKER_MODEL=bge-reranker

# LangGraph workflow backend.
WORKFLOW_BACKEND=langgraph
